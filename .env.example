# Your domain names (used in Traefik labels)
COUCHDB_HOST=couchdb.yourdomain.com
MCP_HOST=obsidian-mcp.yourdomain.com

# CouchDB credentials (used by obsidian-headless for sync)
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme

# obsidian-mcp bearer token (must match what you configure in Claude's MCP settings)
SEMANTIC_BEARER=changeme

# JWT secret for the obsidian-mcp OAuth flow
JWT_SECRET=changeme

# Password shown on the OAuth consent screen
AUTHORIZE_PASSWORD=changeme

# Obsidian Local REST API key (copy from plugin settings after first boot)
OBSIDIAN_API_KEY=placeholder
